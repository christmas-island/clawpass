{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/christmas-island/clawpass/schemas/list.schema.json",
  "title": "clawpass list output",
  "description": "JSON written to stdout by the list command. Shape depends on exit code.",
  "oneOf": [
    {
      "title": "list success (exit 0)",
      "type": "object",
      "properties": {
        "ok": { "const": true },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "integer", "minimum": 1 },
              "session_id": { "type": "string", "minLength": 1 },
              "prompt": { "type": "string", "minLength": 1 },
              "created_at": { "type": "string", "format": "date-time" }
            },
            "required": ["id", "session_id", "prompt", "created_at"],
            "additionalProperties": false
          }
        }
      },
      "required": ["ok", "items"],
      "additionalProperties": false
    },
    {
      "title": "list empty (exit 2)",
      "description": "Note: unlike pop/peek empty, this has no session_id field.",
      "type": "object",
      "properties": {
        "ok": { "const": false },
        "reason": { "const": "empty" }
      },
      "required": ["ok", "reason"],
      "additionalProperties": false
    }
  ]
}
